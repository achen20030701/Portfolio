# DeepSeek API 配置
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# DashScope Embedding 配置
DASHSCOPE_API_KEY=your_dashscope_key_here

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000

# RAG 配置
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5

# 检索策略配置
USE_HYBRID_SEARCH=true
USE_RERANK=true
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7
